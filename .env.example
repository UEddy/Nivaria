# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Session secret. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED: change this before deploying to production
SESSION_SECRET=your_64_char_random_hex_session_secret_here

# Comma-separated emails allowed to view /admin/* pages (e.g. the waitlist).
# Empty/unset = no admins (everyone gets 403). Set this in Railway for prod.
ADMIN_EMAILS=

# Resend (email delivery for OTP codes)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=Nivaria <onboarding@resend.dev>

# Anthropic AI (required for change analysis)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Phase 10: Lemon Squeezy subscription payments ─────────────────────────────
# Lemon Squeezy is the merchant of record (handles all PCI/card data; we store
# none). All values below come from https://app.lemonsqueezy.com with Test Mode
# toggled ON (top-right of the dashboard) for the entire Phase 10 build.
#
# 1. API key — Settings → API → "Create API key". Server-side ONLY; never shipped
#    to the client, never logged.
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
# 2. Store ID — Settings → Stores (the numeric id of your store).
LEMONSQUEEZY_STORE_ID=your_store_id_here
# 3. Pro product variant id — Products → "Nivaria Pro" → the variant's id.
#    (Subscription, $20/month. Copy the *variant* id, not the product id.)
LEMONSQUEEZY_PRO_VARIANT_ID=your_pro_variant_id_here
# 4. Webhook signing secret — Settings → Webhooks → New webhook. Generate a
#    strong random string as the signing secret and paste the SAME value here.
#    Subscribe the webhook to all subscription_* events. Request URL during
#    testing is your ngrok URL: https://<ngrok>/api/webhooks/lemonsqueezy
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret_here
# 5. Test mode. Leave 'true' for the entire Phase 10 build; flip to 'false' only
#    in Phase 13 when going live. Anything other than the literal 'false' = test.
LEMONSQUEEZY_TEST_MODE=true

# Optional: default Slack/Discord webhooks for all users
DEFAULT_SLACK_WEBHOOK=
DEFAULT_DISCORD_WEBHOOK=

# ── Phase 7: Calendar OAuth (pre-meeting briefings) ───────────────────────────
# Encryption key for calendar OAuth tokens at rest. AES-256-GCM, 32 bytes hex.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED before any calendar can be connected.
CALENDAR_TOKEN_ENCRYPTION_KEY=your_64_char_random_hex_calendar_key_here

# Google Calendar OAuth (required to connect a Google account).
# 1. Open https://console.cloud.google.com/apis/credentials
# 2. Create a new project (or pick one), then "Create Credentials" → "OAuth client ID"
# 3. Application type: "Web application"
# 4. Authorized redirect URIs: add exactly the value of GOOGLE_OAUTH_REDIRECT_URI below
# 5. Enable the Google Calendar API for the project (APIs & Services → Library)
# 6. Copy the client ID and secret into these vars
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback

# Microsoft 365 Calendar OAuth — stubbed for now (UI shows "Coming soon").
# When implemented, register an app at https://entra.microsoft.com → "App registrations".
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/microsoft/callback

# Set to any truthy value (e.g. 1) to emit verbose [calendar:connect] /
# [calendar:callback] log lines while diagnosing OAuth flow issues. Off by
# default — tokens are already redacted in those lines, but silencing them
# in production keeps log volume bounded.
OAUTH_DEBUG=

# ── Phase 9: Slack deal logging (win/loss + ROI) ──────────────────────────────
# Lets users log deals from Slack with: /foresight lost-deal Acme $40K vs BambooHR
#
# 1. Create a Slack app at https://api.slack.com/apps -> "From scratch".
# 2. Basic Information -> App Credentials -> copy the "Signing Secret" here.
#    This is REQUIRED: the slash command endpoint rejects any request that
#    isn't correctly signed by Slack (with a 5-minute replay window).
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
#
# 3. OAuth & Permissions -> Bot Token Scopes -> add "commands".
#    Redirect URLs -> add exactly the value of SLACK_REDIRECT_URI below.
#    Copy the Client ID / Client Secret from Basic Information -> App Credentials.
#    (Leave these blank to hide the in-app "Add to Slack" button; signature
#    verification still works for a manually configured slash command.)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/slack/oauth/callback
#
# 4. Slash Commands -> Create New Command:
#      Command:           /foresight
#      Request URL:       https://YOUR_HOST/api/slack/commands
#      Short description: Log a win/loss deal outcome
#      Usage hint:        lost-deal Acme $40K vs BambooHR
# 5. Interactivity & Shortcuts -> turn on, Request URL:
#      https://YOUR_HOST/api/slack/interactions
#    (Needed for the competitor-picker buttons when a name doesn't match.)
